
module uart_rx(
    input clk_3125,
    input rx,
    output reg [7:0] rx_msg,
    output reg rx_parity,
    output reg rx_complete
    );

initial begin
    rx_msg = 8'b0;
    rx_parity = 1'b0;
    rx_complete = 1'b0;
end
//////////////////DO NOT MAKE ANY CHANGES ABOVE THIS LINE//////////////////

localparam	IDLE 			= 3'b000,
				START_BIT 	= 3'b001,
				DATA_BITS	= 3'b010,
				PARITY_BIT  = 3'b011,
		      STOP_BIT 	= 3'b100;
				
// Clock and baudrate parameters
localparam integer BAUD_TICKS = 27; // ≈ 3125kHz / 115200 baud

// Reg definitions and initial block alignment
reg [2:0] state;
reg [7:0] data_buf;
reg [3:0] bit_index;
reg [4:0] tick_count;
reg parity_calc; // calculated parity bit
reg parity_recv; // received parity bit

initial begin
    state       = IDLE;
    data_buf    = 8'd0;
	 bit_index   = 4'd0;
	 tick_count  = 5'd0;
	 parity_calc = 1'd0;
	 parity_recv = 1'd0;
end

always @(posedge clk_3125) begin
	case (state)
		// IDLE: waiting for start signal
		IDLE: begin
			rx_complete <= 1'b0;
         bit_index   <= 4'd0;
			parity_calc <= 1'b0;
			if (rx == 1'b0) begin // detect start bit
				state <= START_BIT;
			end
		end
		

		// START_BIT: recieve start bit (0)
		START_BIT: begin
			tick_count <= tick_count + 5'd1;
			if (tick_count == (BAUD_TICKS-1)) begin 
			   if (rx == 1'b0) begin // valid start 
					tick_count <= 5'd0;
					bit_index  <= 4'd0;
					state      <= DATA_BITS;
			   end
				else begin
					// False start
					tick_count <= 5'd0;
					state      <= IDLE;
				end
			end	
		end
		
		// DATA_BITS: Receive 8 bit data (MSB first)
		DATA_BITS: begin
			 tick_count <= tick_count + 5'd1;

			 // Sample in middle of bit
			 if (tick_count == (BAUD_TICKS/2)) begin
				  data_buf[7 - bit_index] <= rx;
				  parity_calc             <= parity_calc ^ rx;
			 end

			 // Move to next bit after full bit duration
			 if (tick_count == (BAUD_TICKS - 1)) begin
				  tick_count <= 0;
				  bit_index   <= bit_index + 4'd1;
				  if (bit_index == 7) begin
						state <= PARITY_BIT;
				  end
			 end
		end
		
		// PARITY_BIT: Receive parity bit
      PARITY_BIT: begin
			tick_count <= tick_count + 5'd1;
         if (tick_count  == (BAUD_TICKS/2)) begin
            parity_recv <= rx;
         end
			
			// Move to stop bit after full bit duration
			if (tick_count == (BAUD_TICKS - 1)) begin
				tick_count <= 0;
				state      <= STOP_BIT;
			end
      end
		 
      // STOP_BIT: Receive stop bit(1)
      STOP_BIT: begin
			tick_count <= tick_count + 5'd1;
			if (tick_count == (BAUD_TICKS/2)) begin
				if (rx == 1'b0) begin // invalid stop bit
					data_buf <= 8'b00000000;
				end 
			end	
         if (tick_count == BAUD_TICKS-1) begin
				tick_count <= 5'd1;     // To compensate for lost cycle 
				if (parity_calc == parity_recv) begin
					rx_msg <= data_buf;
			   end
				else begin
					rx_msg <= 8'b00111111; // Send '?' on parity error
				end
				rx_parity   <= parity_recv;
				rx_complete <= 1'b1;
				state       <= IDLE;
			end
		end 
		
		default: state <= IDLE;
		
	endcase
end

//////////////////DO NOT MAKE ANY CHANGES BELOW THIS LINE//////////////////

endmodule
